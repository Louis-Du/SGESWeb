@*
        _TextBox.cshtml — Componente reutilizable de campo de texto

    Parámetros (vía ViewData al invocar el partial):
        "id"          : string  — Atributo id/name del input (requerido)
        "label"       : string  — Etiqueta visible del campo (requerido)
        "value"       : object  — Valor actual del campo (opcional)
        "placeholder" : string  — Texto de ayuda dentro del input (opcional)
        "type"        : string  — Tipo HTML: text | email | number | password | date (default: "text")
        "required"    : bool    — Marca el campo como obligatorio (default: false)
        "disabled"    : bool    — Deshabilita el campo (default: false)
        "readonly"    : bool    — Campo de solo lectura (default: false)
        "cssClass"    : string  — Clases CSS adicionales para el input (opcional)
        "helpText"    : string  — Texto de ayuda debajo del campo (opcional)
        "maxLength"   : int     — Longitud máxima permitida (opcional)
        "contador"    : bool    — Muestra contador de caracteres dentro del input (requiere maxLength)
        "max"         : string  — Valor máximo permitido (para type="number" o fechas)
        "min"         : string  — Valor mínimo permitido (para type="number" o fechas)

    Uso básico:
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData) {
            { "id",          "nombre" },
            { "label",       "Nombre" },
            { "value",       Model.Nombre },
            { "placeholder", "Ingrese el nombre..." },
            { "required",    true }
        })
*@
@{
    var id = ViewData["id"]?.ToString() ?? "campo";
    var label = ViewData["label"]?.ToString() ?? "Campo";
    var value = ViewData["value"];
    var placeholder = ViewData["placeholder"]?.ToString() ?? "";
    var type = ViewData["type"]?.ToString() ?? "text";
    var required = ViewData["required"] is bool && (bool)ViewData["required"];
    var disabled = ViewData["disabled"] is bool && (bool)ViewData["disabled"];
    var readOnly = ViewData["readonly"] is bool && (bool)ViewData["readonly"];
    var cssClass = ViewData["cssClass"]?.ToString() ?? "";
    var helpText = ViewData["helpText"]?.ToString();
    var maxLength = ViewData["maxLength"];
    var contador = ViewData["contador"] is bool && (bool)ViewData["contador"];
    var max = ViewData["max"]?.ToString();
    var min = ViewData["min"]?.ToString();

    var inputClass = "form-control sges-input " + cssClass;
    var helpId = id + "Help";
    var contadorId = id + "Contador";
    var valorActual = value?.ToString() ?? "";
    var limiteInt = maxLength != null ? Convert.ToInt32(maxLength) : 0;
}

<div class="mb-3 sges-field">
    <label for="@id" class="form-label sges-label">
        @label
        @if (required)
        {
            <span class="text-danger ms-1" title="Campo obligatorio" aria-hidden="true">*</span>
        }
    </label>

    @* ── Input ── *@
    <input type="@type"
           id="@id"
           name="@id"
           class="@inputClass"
           value="@value"
           placeholder="@placeholder"
           @(required ? "required" : "")
           @(disabled ? "disabled" : "")
           @(readOnly ? "readonly" : "")
           @(maxLength != null ? $"maxlength=\"{maxLength}\"" : "")
           @(!string.IsNullOrEmpty(max) ? $"max=\"{max}\"" : "")
           @(!string.IsNullOrEmpty(min) ? $"min=\"{min}\"" : "")
           aria-describedby="@(contador ? contadorId : "") @(!string.IsNullOrEmpty(helpText) ? helpId : "")" />

    @* ── Contador (debajo del input, alineado a la izquierda) ── *@
    @if (contador && limiteInt > 0)
    {
        <div id="@contadorId" class="form-text sges-help-text" style="font-size:.75rem; color:var(--sges-text-muted);">
            @valorActual.Length / @limiteInt
        </div>
    }

    @* ── Texto de ayuda (debajo del contador) ── *@
    @if (!string.IsNullOrEmpty(helpText))
    {
        <div id="@helpId" class="form-text sges-help-text mt-1">@helpText</div>
    }

    @* ── Script para actualizar el contador en tiempo real ── *@
    @if (contador && limiteInt > 0)
    {
        <script>
            (function () {
                var inp = document.getElementById("@id");
                var contador = document.getElementById("@contadorId");
                var limit = @limiteInt;
                if (!inp || !contador) return;

                inp.addEventListener("input", function () {
                    var usado = inp.value.length;
                    contador.textContent = usado + " / " + limit;
                    contador.style.color = usado >= limit
                        ? "var(--sges-danger)"
                        : "var(--sges-text-muted)";
                });
            }());
        </script>
    }
</div>