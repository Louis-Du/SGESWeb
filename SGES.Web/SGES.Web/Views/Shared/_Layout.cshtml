    "INICIO DE SESIÓN: Se ingresa con ID numérico y contraseña. La contraseña es sensible a mayúsculas y minúsculas.";

                var btn = document.getElementById("sges-chat-btn");
                var box = document.getElementById("sges-chat-box");
                var messages = document.getElementById("sges-chat-messages");
                var input = document.getElementById("sges-chat-input");
                var send = document.getElementById("sges-chat-send");

                // ── Cargar historial guardado en sessionStorage ────────────────────
                // sessionStorage persiste mientras la pestaña esté abierta,
                // así el chat no se reinicia al navegar entre páginas.
                function cargarHistorial() {
                    var historial = JSON.parse(sessionStorage.getItem("sges-chat-historial") || "[]");
                    historial.forEach(function (msg) {
                        renderMensaje(msg.texto, msg.tipo);
                    });
                    // Si no hay historial, mostramos el mensaje de bienvenida
                    if (historial.length === 0) {
                        renderMensaje("¡Hola! Soy el asistente del SGES. Puedo ayudarte con preguntas sobre eventos e inscripciones. ¿En qué te puedo ayudar?", "bot");
                        guardarEnHistorial("¡Hola! Soy el asistente del SGES. Puedo ayudarte con preguntas sobre eventos e inscripciones. ¿En qué te puedo ayudar?", "bot");
                    }
                }

                // ── Guardar mensaje en sessionStorage ─────────────────────────────
                function guardarEnHistorial(texto, tipo) {
                    var historial = JSON.parse(sessionStorage.getItem("sges-chat-historial") || "[]");
                    historial.push({ texto: texto, tipo: tipo });
                    sessionStorage.setItem("sges-chat-historial", JSON.stringify(historial));
                }

                // ── Renderizar burbuja en pantalla (sin guardar) ──────────────────
                function renderMensaje(texto, tipo) {
                    var div = document.createElement("div");
                    div.className = tipo === "bot" ? "sges-msg-bot" : "sges-msg-user";
                    div.textContent = texto;
                    messages.appendChild(div);
                    messages.scrollTop = messages.scrollHeight;
                }

                // ── Agregar mensaje: renderiza Y guarda en historial ──────────────
                function agregarMensaje(texto, tipo) {
                    renderMensaje(texto, tipo);
                    guardarEnHistorial(texto, tipo);
                }

                function mostrarEscribiendo() {
                    var div = document.createElement("div");
                    div.className = "sges-msg-bot";
                    div.id = "sges-escribiendo";
                    div.textContent = "Escribiendo...";
                    messages.appendChild(div);
                    messages.scrollTop = messages.scrollHeight;
                }

                function ocultarEscribiendo() {
                    var el = document.getElementById("sges-escribiendo");
                    if (el) el.remove();
                }

                function enviarMensaje() {
                    var texto = input.value.trim();
                    if (!texto) return;

                    agregarMensaje(texto, "user");
                    input.value = "";
                    send.disabled = true;
                    mostrarEscribiendo();

                    var body = JSON.stringify({
                        contents: [{
                            role: "user",
                            parts: [{ text: SYSTEM_CONTEXT + "\n\nPregunta del usuario: " + texto }]
                        }]
                    });

                    fetch("https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=" + GEMINI_API_KEY, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: body
                    })
                        .then(function (res) { return res.json(); })
                        .then(function (data) {
                            ocultarEscribiendo();
                            var respuesta = data.candidates &&
                                data.candidates[0] &&
                                data.candidates[0].content &&
                                data.candidates[0].content.parts &&
                                data.candidates[0].content.parts[0].text;
                            agregarMensaje(respuesta || "No pude procesar tu pregunta. Intenta de nuevo.", "bot");
                        })
                        .catch(function () {
                            ocultarEscribiendo();
                            agregarMensaje("Ocurrió un error al conectar con el asistente. Verifica tu conexión e intenta de nuevo.", "bot");
                        })
                        .finally(function () {
                            send.disabled = false;
                            input.focus();
                        });
                }

                btn.addEventListener("click", function () {
                    var isOpen = box.style.display === "flex";
                    box.style.display = isOpen ? "none" : "flex";
                    if (!isOpen) input.focus();
                });

                send.addEventListener("click", enviarMensaje);
                input.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") enviarMensaje();
                });

                // ── Cargar historial al iniciar la página ─────────────────────────
                cargarHistorial();
            }());
        </script>
    }
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    @if (_hasNotif)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var el = document.getElementById("sgesNotificacion");
                if (el) { new bootstrap.Toast(el).show(); }
            });
        </script>
    }
    @if (_hasConfirm)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var modal = new bootstrap.Modal(document.getElementById("modalConfirmarEliminar"));
                modal.show();
            });
        </script>
    }
</body>
</html>
