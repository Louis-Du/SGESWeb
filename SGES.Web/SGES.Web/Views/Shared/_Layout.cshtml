<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SGES</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
        <div class="container">
            @Html.ActionLink("SGES", "Login", "Auth", new { area = "" }, new { @class = "navbar-brand" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    @if (Session["Usuario"] != null)
                    {
                        var u = (SGES.Web.Models.UsuarioSesion)Session["Usuario"];
                        if (u.Tipo == "Administrador")
                        {
                            <li>@Html.ActionLink("Crear Evento", "CrearEvento", "Evento", new { area = "" }, new { @class = "nav-link" })</li>
                        }
                        <li>@Html.ActionLink("Listado", "Listado", "Evento", new { area = "" }, new { @class = "nav-link" })</li>
                    }
                </ul>
                @if (Session["Usuario"] != null)
                {
                    var u = (SGES.Web.Models.UsuarioSesion)Session["Usuario"];
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="nav-link text-white-50">
                                <i class="bi bi-person-circle me-1"></i>@u.Nombre
                            </span>
                        </li>
                        <li class="nav-item">
                            @Html.ActionLink(
                               "Cerrar sesión", "Logout", "Auth", new { area = "" }, 
                               new { 
                                   @class = "nav-link", 
                                   onclick = "return confirm('¿Está seguro que desea cerrar la sesión?');" 
                               }
                            )
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container body-content mt-4">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - SGES</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
