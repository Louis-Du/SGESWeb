@{
    ViewBag.Title = "Inscribir Grupo";
    var evento = ViewBag.Evento as SGES.Web.Models.EventoModel;
    var disponibles = ViewBag.Disponibles as List<SGES.Web.Models.AprendizModel>;
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Inscribir Grupo" },
    { "icono",     "bi-people" },
    { "subtitulo", $"Selecciona hasta {evento.CupoMaximo - 1} compañeros (tú ya estás incluido)" }
})

@using (Html.BeginForm("InscribirGrupo", "Evento", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="idEvento" value="@evento.IdEvento" />

    <div class="row">
        <div class="col-md-6">
            <h6>Aprendices disponibles</h6>
            <ul class="list-group" id="listaDisponibles">
                @foreach (var aprendiz in disponibles)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center"
                        data-id="@aprendiz.IdApr" data-nombre="@aprendiz.NombreApr">
                        @aprendiz.NombreApr
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                onclick="agregarAlGrupo(this)">
                            Agregar
                        </button>
                    </li>
                }
            </ul>
        </div>

        <div class="col-md-6">
            <h6>Mi grupo <span id="contadorGrupo">@($"(1/{evento.CupoMaximo})")</span></h6> 
            <ul class="list-group" id="listaGrupo">
                <li class="list-group-item">Tú (inscrito automáticamente)</li>
            </ul>
            <div id="inputsOcultos"></div>
        </div>
    </div>

    <div class="mt-3">
        @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Confirmar inscripción" },
            { "icono", "bi-check-circle" }
        })
        @Html.Partial("_BotonCancelar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Volver" },
            { "url",   Url.Action("Details", "Evento", new { id = evento.IdEvento }) }
        })
    </div>
}

@section scripts {
    <script>
    var grupo = [];
    var cupoMaximo = @(evento.CupoMaximo);        // valor dinámico desde el evento
    var limiteCompaneros = cupoMaximo - 1;        // descontando al usuario actual

    function agregarAlGrupo(btn) {
        var li = btn.closest("li");
        var id = li.dataset.id;
        // Evitar agregar el mismo aprendiz más de una vez desde el front-end
        if (grupo.indexOf(id) !== -1) {
            return;
        }           

        if (grupo.length >= limiteCompaneros) {
            alert("El grupo ya alcanzó el máximo de " + cupoMaximo + " integrantes (incluyéndote a ti).");
            return;
        }
        var nombre = li.dataset.nombre;

        grupo.push(id);

        var listaGrupo = document.getElementById("listaGrupo");
        var nuevoLi = document.createElement("li");
        nuevoLi.className = "list-group-item d-flex justify-content-between align-items-center";
        nuevoLi.dataset.id = id;
        nuevoLi.innerHTML = nombre +
            '<button type="button" class="btn btn-sm btn-outline-danger" onclick="quitarDelGrupo(this)">Quitar</button>';
        listaGrupo.appendChild(nuevoLi);

        var input = document.createElement("input");
        input.type = "hidden";
        input.name = "seleccionados";
        input.value = id;
        input.id = "input_" + id;
        document.getElementById("inputsOcultos").appendChild(input);

        // Marcar el botón como agregado y deshabilitarlo para evitar duplicados
        btn.disabled = true;
        btn.textContent = 'Agregado';
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-success');

        actualizarContador();
    }

    function quitarDelGrupo(btn) {
        var li = btn.closest("li");
        var id = li.dataset.id;

        grupo = grupo.filter(function(x) { return x !== id; });

        var disponible = document.querySelector("#listaDisponibles [data-id='" + id + "']");
        if (disponible) disponible.style.display = "";

        var input = document.getElementById("input_" + id);
        if (input) input.remove();

        li.remove();
        // Si existe el botón en la lista de disponibles, reestablecer su estado
        if (disponible) {
            var btnDisp = disponible.querySelector('button');
            if (btnDisp) {
                btnDisp.disabled = false;
                btnDisp.textContent = 'Agregar';
                btnDisp.classList.remove('btn-success');
                btnDisp.classList.add('btn-outline-primary');
            }
        }
        actualizarContador();
    }

    function actualizarContador() {
        document.getElementById("contadorGrupo").textContent =
            "(" + (grupo.length + 1) + "/" + cupoMaximo + ")";
    }
    </script>
}