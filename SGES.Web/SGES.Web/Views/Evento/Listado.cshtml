@using System.Linq
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos disponibles";

    // Preparar datos para _TablaBasica
    var columnas = new[] { "Nombre", "Tipo", "Inicio", "Fin" };

    var filas = Model != null
        ? Model.Select(e => new object[]
            {
                e.NombreEvento,
                e.TipoEvento,
                e.FechaHoraInicio.ToString("g"),
                e.FechaHoraFin.ToString("g")
                    }.AsEnumerable())
        : Enumerable.Empty<IEnumerable<object>>();
}

@{
    // Construir el HTML de la tabla para pasarlo al _Card como cuerpoHtml
    var tablaHtml = new System.Text.StringBuilder();
    using (var sw = new System.IO.StringWriter())
    {
        ViewData["columnas"] = columnas;
        ViewData["filas"] = filas;
        ViewData["titulo"] = null;
        ViewData["mensajeVacio"] = "No hay eventos disponibles en este momento.";

        Html.RenderPartial("_TablaBasica");
    }
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Eventos disponibles" },
    { "icono",     "bi-calendar-event" },
    { "subtitulo", "Próximos eventos registrados en el sistema" },
    { "shadow",    "sm" },
    { "color",     "" },
    { "columnas",  columnas },
    { "filas",     filas }
})
Espera — el problema con _Card es que recibe cuerpoHtml como string, pero _TablaBasica se renderiza como partial. La forma correcta en MVC Framework antiguo es esta:
cshtml@using System.Linq
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos disponibles";

    var columnas = new[] { "Nombre", "Tipo", "Inicio", "Fin" };

    var filas = Model != null
        ? Model.Select(e => new object[]
            {
                e.NombreEvento,
                e.TipoEvento,   
                e.FechaHoraInicio.ToString("g"),
                e.FechaHoraFin.ToString("g")
                    }.AsEnumerable())
        : Enumerable.Empty<IEnumerable<object>>();

    // Renderizar _TablaBasica a string para pasarlo a _Card
    ViewData["columnas"] = columnas;
    ViewData["filas"] = filas;
    ViewData["mensajeVacio"] = "No hay eventos disponibles en este momento.";

    var tablaHtml = new System.Text.StringBuilder();
    using (var sw = new System.IO.StringWriter())
    {
        var ctx = new System.Web.Mvc.ViewContext(
            ViewContext, ViewContext.View, ViewData, TempData, sw);
        Html.RenderPartial("_TablaBasica");
        tablaHtml.Append(sw.ToString());
    }
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",     "Eventos disponibles" },
    { "icono",      "bi-calendar-event" },
    { "subtitulo",  "Próximos eventos registrados en el sistema" },
    { "shadow",     "sm" },
    { "cuerpoHtml", tablaHtml.ToString() }
})
