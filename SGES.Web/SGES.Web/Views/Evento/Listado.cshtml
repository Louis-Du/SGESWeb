@using System.Linq
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos Disponibles";
}

@if (TempData["Success"] != null)
{
    <script>
        alert("@TempData["Success"]");
    </script>
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Menú de inicio para el aprendiz" },
    { "icono",     "house-door-fill" },
    { "subtitulo", "Seleccione un evento para inscribirse" }
})

<div class="table-responsive">
    <table class="table table-striped table-hover sges-tabla">
        <thead class="sges-tabla-thead">
            <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th class="text-center">Acción</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                        No hay eventos disponibles en este momento.
                    </td>
                </tr>
            }
            else
            {
                foreach (var e in Model)
                {
                    <tr>
                        <td>@e.NombreEvento</td>
                        <td>@e.TipoEvento</td>
                        <td>@e.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@e.FechaHoraFin.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            @Html.Partial("_BotonIr", null, new ViewDataDictionary(ViewData)
                            {
                                { "texto", "Ver / Inscribirse" },
                                { "icono", "bi-box-arrow-in-right" },
                                { "url",   Url.Action("Details", "Evento", new { id = e.IdEvento }) },
                                { "class", "btn-sm" }
                            })
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>