@using System.Web.Mvc
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos Disponibles";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Menú de inicio para el aprendiz" },
    { "icono",     "bi-house-door-fill" },
    { "subtitulo", "Elija una acción" }
})

@Html.Partial("_TablaSeleccion", null, new ViewDataDictionary(ViewData)
{
    { "titulo",        "Listado de Eventos" },
    { "seleccionable", true },
    { "idFila",        Model.Select(e => (object)e.IdEvento) },
    { "columnas",      new[] { "Nombre", "Tipo", "Modalidad", "Tipo de inscripcion", "Inicio", "Fin" } },
    { "filas",         Model.Select(e => new object[]
        {
            e.NombreEvento,
            e.TipoEvento,
            e.ModalidadEvento,
            e.TipoInscrip,
            e.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm"),
            e.FechaHoraFin.ToString("dd/MM/yyyy HH:mm")
        })
    }
})

@Html.Partial("_BotonIr", null, new ViewDataDictionary(ViewData)
{
    { "texto", "Ver / Inscribirse" },
    { "icono", "bi-box-arrow-in-right" },
    { "id",    "btnVerInscribirse" }
})

@{ var filtro = ViewBag.Filtro as SGES.Web.Models.EventoFiltroModel; }

@using (Html.BeginForm("InicioAprendiz", "Evento", FormMethod.Get))
{
    @Html.TextBox("Nombre", filtro != null ? filtro.Nombre : "",
        new { @class = "form-control", placeholder = "Buscar por nombre..." })

<div class="mb-3">
    <input type="date" name="Fecha"
           value="@(filtro != null && filtro.Fecha.HasValue ? filtro.Fecha.Value.ToString("yyyy-MM-dd") : "")"
           class="form-control" />
</div>

    @Html.Partial("_ComboBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",            "Modalidad" },
        { "label",         "Modalidad" },
        { "items",         ViewBag.Modalidades },
        { "selectedValue", filtro != null ? filtro.Modalidad : "" },
        { "defaultOption", "Todas" },
        { "required",      false }
    })

    @Html.Partial("_ComboBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",            "TipoInscrip" },
        { "label",         "Tipo de Inscripción" },
        { "items",         ViewBag.TiposInscripcion },
        { "selectedValue", filtro != null ? filtro.TipoInscrip : "" },
        { "defaultOption", "Todos" },
        { "required",      false }
    })

    <button type="submit" class="btn btn-primary">Buscar</button>
    <a href="@Url.Action("InicioAprendiz")" class="btn btn-secondary">Limpiar</a>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var btn = document.getElementById("btnVerInscribirse");
            if (!btn) return;

            btn.addEventListener("click", function (e) {
                e.preventDefault();
                var sel = document.querySelector('input[name="filaSeleccionada"]:checked');
                if (!sel || !sel.value) {
                    alert("Debe seleccionar un evento antes de continuar.");
                    return;
                }
                window.location.href = '@Url.Action("Details", "Evento")' + '?id=' + encodeURIComponent(sel.value);
            });
        });
    </script>
}
