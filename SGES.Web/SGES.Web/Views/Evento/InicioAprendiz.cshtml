﻿@using System.Web.Mvc
@functions {
    public string ObtenerColorTipo(string tipo)
    {
        switch (tipo)
        {
            case "Educativo": return "primary";
            case "Deportivo": return "success";
            case "Social": return "warning text-dark";
            case "Cultural": return "info";
            default: return "secondary";
        }
    }
}
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos Disponibles";
    var columnas = new[] { "Nombre", "Tipo", "Modalidad", "Tipo de inscripcion", "Inicio", "Fin" };
    var filas = Model?.Select(e => new object[] {
        e.NombreEvento,
        new HtmlString($"<span class='badge bg-{ObtenerColorTipo(e.TipoEvento)}'>{e.TipoEvento}</span>"),
        e.ModalidadEvento,
        e.TipoInscrip,
        e.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm"),
        e.FechaHoraFin.ToString("dd/MM/yyyy HH:mm")
    }) ?? Enumerable.Empty<object[]>();
    var ids = Model?.Select(e => (object)e.IdEvento) ?? Enumerable.Empty<object>();
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Menú de inicio para el aprendiz" },
    { "icono",     "bi-house-door-fill" },
    { "subtitulo", "Elija una acción" },
    { "cuerpo", new Func<object, HelperResult>(@<text>

    @{
    var filtro = ViewBag.Filtro as SGES.Web.Models.EventoFiltroModel;
    var hayFiltro = filtro != null && (!string.IsNullOrEmpty(filtro.Nombre) || filtro.Fecha.HasValue || !string.IsNullOrEmpty(filtro.Modalidad) || !string.IsNullOrEmpty(filtro.TipoInscrip));
    }

    @Html.Partial("_PanelFiltros", null, new ViewDataDictionary(ViewData)
        {
        { "accion", "InicioAprendiz" },
        { "controlador", "Evento" },
        { "hayFiltro", hayFiltro },
        { "campos", new System.Web.Mvc.MvcHtmlString(
            "<div class='col-md-3 col-sm-6'>" +
                Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData) {
                    { "id", "Nombre" }, { "label", "Nombre" }, { "type", "text" },
                    { "placeholder", "Buscar por nombre..." }, { "value", filtro?.Nombre }
                }).ToString() +
            "</div>" +
            "<div class='col-md-2 col-sm-6'>" +
                Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData) {
                    { "id", "Fecha" }, { "label", "Fecha" }, { "type", "date" },
                    { "value", filtro?.Fecha?.ToString("yyyy-MM-dd") }
                }).ToString() +
            "</div>" +
            "<div class='col-md-2 col-sm-6'>" +
                Html.Partial("_ComboBox", null, new ViewDataDictionary(ViewData) {
                    { "id", "Modalidad" }, { "label", "Modalidad" },
                    { "items", ViewBag.Modalidades }, { "defaultOption", "Todas" },
                    { "selectedValue", filtro?.Modalidad }
                }).ToString() +
            "</div>" +
            "<div class='col-md-2 col-sm-6'>" +
                Html.Partial("_ComboBox", null, new ViewDataDictionary(ViewData) {
                    { "id", "TipoInscrip" }, { "label", "Tipo de Inscripción" },
                    { "items", ViewBag.TiposInscripcion }, { "defaultOption", "Todos" },
                    { "selectedValue", filtro?.TipoInscrip }
                }).ToString() +
            "</div>"
        )}
    })

    @Html.Partial("_TablaSeleccion", null, new ViewDataDictionary(ViewData)
        {
        { "titulo",        "Listado de Eventos" },
        { "seleccionable", true },
        { "idFila",        ids },
        { "columnas",      columnas },
        { "filas",         filas }
    })

    <div class="mt-3">
        @Html.Partial("_BotonIr", null, new ViewDataDictionary(ViewData)
                {
            { "texto", "Ver / Inscribirse" },
            { "icono", "bi-box-arrow-in-right" },
            { "id",    "btnVerInscribirse" }
        })
    </div>
    </text>)}
})

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ── 1. Botón "Ver / Inscribirse" ──
            var btn = document.getElementById("btnVerInscribirse");
            if (btn) {
                btn.addEventListener("click", function (e) {
                    e.preventDefault();
                    var sel = document.querySelector('input[name="filaSeleccionada"]:checked');
                    if (!sel || !sel.value) {
                        sgesUI.alert("Debe seleccionar un evento antes de continuar.");
                        return;
                    }
                    window.location.href = '@Url.Action("Details", "Evento")' + '?id=' + encodeURIComponent(sel.value);
                });
            }

            // ── 2. Filtro automático en el panel de filtros ──
            var panelFiltros = document.getElementById("panelFiltros");
            if (panelFiltros) {
                var form = panelFiltros.querySelector("form");
                if (form) {
                    var inputNombre = document.getElementById("Nombre");
                    if (inputNombre) {
                        var timeoutNombre;
                        inputNombre.addEventListener("input", function () {
                            clearTimeout(timeoutNombre);
                            timeoutNombre = setTimeout(function () {
                                form.submit();
                            }, 500);
                        });
                    }

                    var inputFecha = document.querySelector("input[name='Fecha']");
                    if (inputFecha) {
                        inputFecha.addEventListener("change", function () {
                            form.submit();
                        });
                    }

                    var comboModalidad = document.getElementById("Modalidad");
                    if (comboModalidad) {
                        comboModalidad.addEventListener("change", function () {
                            form.submit();
                        });
                    }

                    var comboTipoInscrip = document.getElementById("TipoInscrip");
                    if (comboTipoInscrip) {
                        comboTipoInscrip.addEventListener("change", function () {
                            form.submit();
                        });
                    }
                }
            }

        });
    </script>
}
