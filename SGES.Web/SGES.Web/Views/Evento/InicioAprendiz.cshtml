@using System.Web.Mvc
@model IEnumerable<SGES.Web.Models.EventoModel>

@{
    ViewBag.Title = "Eventos Disponibles";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Menú de inicio para el aprendiz" },
    { "icono",     "bi-house-door-fill" },
    { "subtitulo", "Elija una acción" },
    { "cuerpo", new Func<object, HelperResult>(@<text>
    @Html.Partial("_TablaSeleccion", null, new ViewDataDictionary(ViewData)
                {
            { "titulo",        "Listado de Eventos" },
            { "seleccionable", true },
            { "idFila",        Model.Select(e => (object)e.IdEvento) },
            { "columnas",      new[] { "Nombre", "Tipo", "Modalidad", "Tipo de inscripcion", "Inicio", "Fin" } },
            { "filas",         Model.Select(e => new object[]
                        {
                    e.NombreEvento,
                    e.TipoEvento,
                    e.ModalidadEvento,
                    e.TipoInscrip,
                    e.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm"),
                    e.FechaHoraFin.ToString("dd/MM/yyyy HH:mm")
                })
            }
        })

    <div class="mt-3">
        @Html.Partial("_BotonIr", null, new ViewDataDictionary(ViewData)
                            {
                { "texto", "Ver / Inscribirse" },
                { "icono", "bi-box-arrow-in-right" },
                { "id",    "btnVerInscribirse" }
            })
    </div>
    </text>)}
})

@{
    var filtro = ViewBag.Filtro as SGES.Web.Models.EventoFiltroModel;
    var hayFiltro = filtro != null && (
        !string.IsNullOrEmpty(filtro.Nombre) ||
        filtro.Fecha.HasValue ||
        !string.IsNullOrEmpty(filtro.Modalidad) ||
        !string.IsNullOrEmpty(filtro.TipoInscrip)
    );
}

@Html.Partial("_PanelFiltros", null, new ViewDataDictionary(ViewData)
{
    { "accion",      "InicioAprendiz" },
    { "controlador", "Evento"      },
    { "hayFiltro",   hayFiltro     },
    { "campos", new System.Web.Mvc.MvcHtmlString(
        @using (Html.BeginForm("RestablecerPassword", "Auth", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
{
        { "id",          "Id" },
        { "label",       "ID de Usuario" },
        { "type",        "text" },
        { "inputmode",   "numeric" },
        { "pattern",     "[0-9]*" },
        { "value",       Model != null ? Model.Id.ToString() : "" },
        { "placeholder", "Ingrese su ID" },
        { "required",    true }
    })
    @Html.ValidationMessage("Id", "", new { @class = "text-danger small" })

@* Nueva contraseña *@
@Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",          "NuevaPassword" },
        { "name",        "nuevaPassword" },
        { "label",       "Nueva contraseña" },
        { "type",        "password" },
        { "placeholder", "Ingrese una nueva contraseña" },
        { "required",    true }
    })
    @Html.ValidationMessage("NuevaPassword", "", new { @class = "text-danger small" })

    @Html.ValidationMessage("NuevaPassword", "", new { @class = "text-danger small" })

@* Confirmar contraseña *@
@Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",          "ConfirmarPassword" },
        { "name",        "confirmarPassword" },
        { "label",       "Confirmar contraseña" },
        { "type",        "password" },
        { "placeholder", "Repita la contraseña" },
        { "required",    true }
    })

    @Html.ValidationMessage("ConfirmarPassword", "", new { @class = "text-danger small" })


    <div class="mt-3">
        @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Cambiar contraseña" },
            { "icono", "bi-key-fill" }
        })

        @Html.Partial("_BotonCancelar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Volver al login" },
            { "url",   Url.Action("Login", "Auth") }
        })
    </div>
}

    )}
})

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var btn = document.getElementById("btnVerInscribirse");
            if (!btn) return;

            btn.addEventListener("click", function (e) {
                e.preventDefault();
                var sel = document.querySelector('input[name="filaSeleccionada"]:checked');
                if (!sel || !sel.value) {
                    sgesUI.alert("Debe seleccionar un evento antes de continuar.");
                    return;
                }
                window.location.href = '@Url.Action("Details", "Evento")' + '?id=' + encodeURIComponent(sel.value);
            });
        });

        (function () {
            // TextBox de nombre — filtra al dejar de escribir (500ms de espera)
            var inputNombre = document.getElementById("Nombre");
            var timeoutNombre;
            inputNombre.addEventListener("input", function () {
                clearTimeout(timeoutNombre);
                timeoutNombre = setTimeout(function () {
                    inputNombre.closest("form").submit();
                }, 500);
            });

            // Date — filtra al seleccionar fecha automáticamente
            var inputFecha = document.querySelector("input[name='Fecha']");
            inputFecha.addEventListener("change", function () {
                inputFecha.closest("form").submit();
            });
        }());

    </script>
}