@model SGES.Web.Models.LoginModel

@{
    ViewBag.Title = "Restablecer contraseña";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Restablecer contraseña" },
    { "icono",     "bi-person-lock" },
    { "subtitulo", "Ingrese la información para cambiar su contraseña" },
    { "cuerpo", new Func<object, HelperResult>(@<text>
    <form action="@Url.Action("RestablecerPassword", "Auth")" method="post">
        @Html.AntiForgeryToken()

        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "Id" },
                { "label",       "ID de Usuario" },
                { "type",        "text" },
                { "inputmode",   "numeric" },
                { "pattern",     "[0-9]*" },
                { "value", Model != null ? Model.Id : "" },
                { "placeholder", "Ingrese su ID" },
                { "required",    true }
            })
        @Html.ValidationMessage("Id", "", new { @class = "text-danger small" })

        @* Nueva contraseña *@
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "NuevaPassword" },
                { "name",        "nuevaPassword" },
                { "label",       "Nueva contraseña" },
                { "type",        "password" },
                { "placeholder", "Ingrese una nueva contraseña" },
                { "required",    true }
            })
        @Html.ValidationMessage("NuevaPassword", "", new { @class = "text-danger small" })

        @* Confirmar contraseña *@
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "ConfirmarPassword" },
                { "name",        "confirmarPassword" },
                { "label",       "Confirmar contraseña" },
                { "type",        "password" },
                { "placeholder", "Repita la contraseña" },
                { "required",    true }
            })
        @Html.ValidationMessage("ConfirmarPassword", "", new { @class = "text-danger small" })

        <div class="mt-3">
            @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
                            {
                    { "texto", "Cambiar contraseña" },
                    { "icono", "bi-key-fill" }
                })

            @Html.Partial("_BotonCancelar", null, new ViewDataDictionary(ViewData)
                            {
                    { "texto", "Volver al login" },
                    { "url",   Url.Action("Login", "Auth") }
                })
        </div>
    </form>
    </text>)}
})

@section scripts {
    <script>
        (function () {
            var id = document.getElementById("Id");
            var nuevaContrasena = document.getElementById("NuevaPassword");
            var confirmarContrasena = document.getElementById("ConfirmarPassword");

            function mostrarError(campo, spanValidation, mensaje) {
                campo.classList.add("is-invalid");
                campo.classList.remove("is-valid");
                if (spanValidation) {
                    spanValidation.textContent = mensaje;
                    spanValidation.style.display = "block";
                }
            }

            function limpiar(campo, spanValidation) {
                campo.classList.remove("is-invalid");
                campo.classList.add("is-valid");
                if (spanValidation) {
                    spanValidation.textContent = "";
                    spanValidation.style.display = "none";
                }
            }

            function getSpan(fieldId) {
                return document.querySelector('[data-valmsg-for="' + fieldId + '"]');
            }

            function validarId() {
                if (!id.value || !id.value.trim()) {
                    mostrarError(id, getSpan("Id"), "El ID no puede estar vacío.");
                    return false;
                }
                limpiar(id, getSpan("Id"));
                return true;
            }

            // Bloquea caracteres no numéricos y muestra error inmediato
            id.addEventListener("keydown", function (e) {
                var permitidos = ["Backspace", "Delete", "ArrowLeft", "ArrowRight", "Tab"];
                if (permitidos.includes(e.key)) return;
                if (!/^[0-9]$/.test(e.key)) {
                    e.preventDefault();
                    mostrarError(id, getSpan("Id"), "Solo se permiten números.");
                }
            });

            // Limpia el error cuando el valor es válido
            id.addEventListener("keyup", function () {
                if (/^[0-9]+$/.test(id.value)) {
                    limpiar(id, getSpan("Id"));
                }
            });

            function validarNuevaContrasena() {
                if (!nuevaContrasena.value || !nuevaContrasena.value.trim()) {
                    mostrarError(nuevaContrasena, getSpan("NuevaPassword"), "La contraseña no puede estar vacía.");
                    return false;
                }
                limpiar(nuevaContrasena, getSpan("NuevaPassword"));
                return true;
            }

            function validarConfirmarContrasena() {
                if (!confirmarContrasena.value || !confirmarContrasena.value.trim()) {
                    mostrarError(confirmarContrasena, getSpan("ConfirmarPassword"), "La contraseña no puede estar vacía.");
                    return false;
                }
                limpiar(confirmarContrasena, getSpan("ConfirmarPassword"));
                return true;
            }

            id.addEventListener("blur", validarId);
            nuevaContrasena.addEventListener("blur", validarNuevaContrasena);
            confirmarContrasena.addEventListener("blur", validarConfirmarContrasena);

            document.querySelector("form").addEventListener("submit", function (e) {
                var ok = validarId() & validarNuevaContrasena() & validarConfirmarContrasena();
                if (!ok) e.preventDefault();
            });
        }());
    </script>
}