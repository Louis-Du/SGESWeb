@model SGES.Web.Models.LoginModel

@{
    ViewBag.Title = "Restablecer contraseña";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Restablecer contraseña" },
    { "icono",     "bi-person-lock" },
    { "subtitulo", "Ingrese la información para cambiar su contraseña" },
    { "cuerpo", new Func<object, HelperResult>(@<text>
    <form action="@Url.Action("RestablecerPassword", "Auth")" method="post">
        @Html.AntiForgeryToken()

        @* Campo ID con límite de 10 caracteres y contador *@
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "Id" },
                { "label",       "ID de Usuario" },
                { "type",        "text" },
                { "inputmode",   "numeric" },
                { "pattern",     "[0-9]*" },
                { "value", Model != null ? Model.Id : "" },
                { "placeholder", "Ingrese su ID" },
                { "required",    true },
                { "maxLength",   10 },
                { "contador",    true }
            })
        @Html.ValidationMessage("Id", "", new { @class = "text-danger small" })

        @* Nueva contraseña *@
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "nuevaPassword" },
                { "label",       "Nueva contraseña" },
                { "type",        "password" },
                { "placeholder", "Ingrese una nueva contraseña" },
                { "required",    true }
            })
        @Html.ValidationMessage("nuevaPassword", "", new { @class = "text-danger small" })

        @* Confirmar contraseña *@
        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "confirmarPassword" },
                { "label",       "Confirmar contraseña" },
                { "type",        "password" },
                { "placeholder", "Repita la contraseña" },
                { "required",    true }
            })
        @Html.ValidationMessage("confirmarPassword", "", new { @class = "text-danger small" })

        <div class="mt-3">
            @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
                            {
                    { "texto", "Cambiar contraseña" },
                    { "icono", "bi-key-fill" }
                })

            @Html.Partial("_BotonCancelar", null, new ViewDataDictionary(ViewData)
                            {
                    { "texto", "Volver al login" },
                    { "url",   Url.Action("Login", "Auth") }
                })
        </div>
    </form>
    </text>)}
})

@section scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var idInput = document.getElementById("Id");
            var nuevaContrasena = document.getElementById("nuevaPassword");
            var confirmarContrasena = document.getElementById("confirmarPassword");

            // ── Helper para mostrar error en el span de validación ──
            function mostrarError(campo, span, mensaje) {
                if (!campo) return;
                campo.classList.add("is-invalid");
                campo.classList.remove("is-valid");
                if (span) {
                    span.textContent = mensaje;
                    span.style.display = "block";
                }
            }

            function limpiar(campo, span) {
                if (!campo) return;
                campo.classList.remove("is-invalid");
                campo.classList.add("is-valid");
                if (span) {
                    span.textContent = "";
                    span.style.display = "none";
                }
            }

            function getSpan(fieldId) {
                return document.querySelector('[data-valmsg-for="' + fieldId + '"]');
            }

            // ── 1. Validación del campo ID ──
            if (idInput) {
                // Bloquear caracteres no numéricos
                idInput.addEventListener("keydown", function (e) {
                    var permitidos = ["Backspace", "Delete", "ArrowLeft", "ArrowRight", "Tab", "Home", "End"];
                    if (permitidos.includes(e.key)) return;
                    if (!/^[0-9]$/.test(e.key)) {
                        e.preventDefault();
                        mostrarError(this, getSpan("Id"), "Solo se permiten números.");
                    }
                });

                // Validar en tiempo real (número y longitud)
                idInput.addEventListener("input", function () {
                    var valor = this.value;

                    // Eliminar caracteres no numéricos
                    var soloNumeros = valor.replace(/[^0-9]/g, '');
                    if (soloNumeros !== valor) {
                        this.value = soloNumeros;
                        valor = soloNumeros;
                        mostrarError(this, getSpan("Id"), "Solo se permiten números.");
                        return;
                    }

                    // Validar longitud
                    if (valor.length > 10) {
                        this.value = valor.slice(0, 10);
                        mostrarError(this, getSpan("Id"), "El ID no puede tener más de 10 dígitos.");
                    } else if (valor.length > 0) {
                        limpiar(this, getSpan("Id"));
                    } else {
                        limpiar(this, getSpan("Id"));
                    }
                });

                // Validación al perder foco
                idInput.addEventListener("blur", function () {
                    var valor = this.value.trim();
                    if (valor === "") {
                        mostrarError(this, getSpan("Id"), "El ID es obligatorio.");
                    } else if (!/^\d{1,10}$/.test(valor)) {
                        mostrarError(this, getSpan("Id"), "El ID debe ser un número de 1 a 10 dígitos.");
                    } else {
                        limpiar(this, getSpan("Id"));
                    }
                });
            }

            // ── 2. Validación de Nueva contraseña ──
            if (nuevaContrasena) {
                nuevaContrasena.addEventListener("blur", function () {
                    if (!this.value.trim()) {
                        mostrarError(this, getSpan("nuevaPassword"), "La contraseña no puede estar vacía.");
                        return false;
                    }
                    limpiar(this, getSpan("nuevaPassword"));
                    return true;
                });
            }

            // ── 3. Validación de Confirmar contraseña ──
            if (confirmarContrasena) {
                confirmarContrasena.addEventListener("blur", function () {
                    if (!this.value.trim()) {
                        mostrarError(this, getSpan("confirmarPassword"), "La confirmación no puede estar vacía.");
                        return false;
                    }
                    limpiar(this, getSpan("confirmarPassword"));
                    return true;
                });
            }

            // ── 4. Validación al enviar el formulario ──
            var form = document.querySelector("form");
            if (form) {
                form.addEventListener("submit", function (e) {
                    var idValido = true;
                    var nuevaOk = true;
                    var confirmOk = true;

                    // Validar ID
                    if (!idInput) idValido = false;
                    else {
                        var idVal = idInput.value.trim();
                        if (idVal === "" || !/^\d{1,10}$/.test(idVal)) {
                            mostrarError(idInput, getSpan("Id"), "El ID debe ser un número de 1 a 10 dígitos.");
                            idValido = false;
                        } else {
                            limpiar(idInput, getSpan("Id"));
                        }
                    }

                    // Validar nueva contraseña
                    if (!nuevaContrasena || !nuevaContrasena.value.trim()) {
                        if (nuevaContrasena) mostrarError(nuevaContrasena, getSpan("nuevaPassword"), "La contraseña no puede estar vacía.");
                        nuevaOk = false;
                    } else {
                        if (nuevaContrasena) limpiar(nuevaContrasena, getSpan("nuevaPassword"));
                    }

                    // Validar confirmación
                    if (!confirmarContrasena || !confirmarContrasena.value.trim()) {
                        if (confirmarContrasena) mostrarError(confirmarContrasena, getSpan("confirmarPassword"), "La confirmación no puede estar vacía.");
                        confirmOk = false;
                    } else {
                        if (confirmarContrasena) limpiar(confirmarContrasena, getSpan("confirmarPassword"));
                    }

                    // Validar que ambas contraseñas coincidan
                    if (nuevaOk && confirmOk && nuevaContrasena && confirmarContrasena) {
                        if (nuevaContrasena.value !== confirmarContrasena.value) {
                            mostrarError(confirmarContrasena, getSpan("confirmarPassword"), "Las contraseñas no coinciden.");
                            confirmOk = false;
                        }
                    }

                    if (!idValido || !nuevaOk || !confirmOk) {
                        e.preventDefault();
                    }
                });
            }
        });
    </script>
}