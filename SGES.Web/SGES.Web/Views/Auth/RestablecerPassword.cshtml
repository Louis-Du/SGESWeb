@model SGES.Web.Models.LoginModel

@{
    ViewBag.Title = "Restablecer contraseña";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Restablecer contraseña" },
    { "icono",     "bi-person-lock" },
    { "subtitulo", "Ingrese la información para cambiar su contraseña" }
})


@using (Html.BeginForm("RestablecerPassword", "Auth", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",          "Id" },
        { "label",       "ID de Usuario" },
        { "type",        "text" },
        { "inputmode",   "numeric" },
        { "pattern",     "[0-9]*" },
        { "value",       Model != null ? Model.Id.ToString() : "" },
        { "placeholder", "Ingrese su ID" },
        { "required",    true }
    })

    @Html.ValidationMessageFor(
        m => m.Id,
        "",
        new { @class = "text-danger small" }
    )


    @* Nueva contraseña *@
    @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",          "NuevaPassword" },
        { "name",        "nuevaPassword" },
        { "label",       "Nueva contraseña" },
        { "type",        "password" },
        { "placeholder", "Ingrese una nueva contraseña" },
        { "required",    true }
    })


    @* Confirmar contraseña *@
    @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
    {
        { "id",          "ConfirmarPassword" },
        { "name",        "confirmarPassword" },
        { "label",       "Confirmar contraseña" },
        { "type",        "password" },
        { "placeholder", "Repita la contraseña" },
        { "required",    true }
    })


    <div class="mt-3">

        @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Cambiar contraseña" },
            { "icono", "bi-key-fill" }
        })


        @Html.Partial("_BotonCancelar", null, new ViewDataDictionary(ViewData)
        {
            { "texto", "Volver al login" },
            { "url", Url.Action("Login","Auth") }
        })

    </div>
}