@model SGES.Web.Models.LoginModel

@{
    ViewBag.Title = "Iniciar Sesión";
}

@Html.Partial("_Card", null, new ViewDataDictionary(ViewData)
{
    { "titulo",    "Iniciar Sesión" },
    { "icono",     "bi-person-lock" },
    { "subtitulo", "Ingrese sus credenciales para continuar" },
    { "cuerpo", new Func<object, HelperResult>(@<text>
    <form action="@Url.Action("Login", "Auth")" method="post">
        @Html.AntiForgeryToken()

        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "Id" },
                { "label",       "ID de Usuario" },
                { "type",        "text" },
                { "inputmode",   "numeric" },
                { "pattern",     "[0-9]*" },
                { "value", Model != null ? Model.Id : "" },
                { "placeholder", "Ingrese su ID" },
                { "required",    true }
            })
        @Html.ValidationMessage("Id", "", new { @class = "text-danger small" })

        @Html.Partial("_TextBox", null, new ViewDataDictionary(ViewData)
                    {
                { "id",          "Contrasena" },
                { "label",       "Contraseña" },
                { "type",        "password" },
                { "placeholder", "Ingrese su contraseña" },
                { "required",    true }
            })
        @Html.ValidationMessage("Contrasena", "", new { @class = "text-danger small" })

        <div class="mt-3">
            @Html.Partial("_BotonGuardar", null, new ViewDataDictionary(ViewData)
                            {
                    { "texto", "Ingresar" },
                    { "icono", "bi-box-arrow-in-right" }
                })
        </div>

        @Html.Partial("_LinkAccion", null, new ViewDataDictionary(ViewData)
                    {
                { "texto", "¿Quieres restablecer tu contraseña?" },
                { "url", Url.Action("RestablecerPassword", "Auth") }
            })
    </form>
    </text>)}
})

@section scripts {
    <script>
        (function () {
            var form = document.querySelector("form");
            console.log("Formulario encontrado:", form);
            if (form) {
                form.addEventListener("submit", function (e) {
                    console.log("Evento submit disparado, action:", form.action);
                });
            }

            // Restricción de caracteres numéricos en ID
            var idInput = document.getElementById("Id");
            if (idInput) {
                idInput.addEventListener("keydown", function (e) {
                    var permitidos = ["Backspace", "Delete", "ArrowLeft", "ArrowRight", "Tab"];
                    if (permitidos.includes(e.key)) return;
                    if (!/^[0-9]$/.test(e.key)) {
                        e.preventDefault();
                        idInput.classList.add("is-invalid");
                        var span = document.querySelector('[data-valmsg-for="Id"]');
                        if (span) {
                            span.textContent = "Solo se permiten números.";
                            span.style.display = "block";
                        }
                    } else {
                        idInput.classList.remove("is-invalid");
                        idInput.classList.add("is-valid");
                        var span = document.querySelector('[data-valmsg-for="Id"]');
                        if (span) {
                            span.textContent = "";
                            span.style.display = "none";
                        }
                    }
                });
            }
        }());
    </script>
}